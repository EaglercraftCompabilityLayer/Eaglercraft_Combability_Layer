{
  "name": "Eaglercraft-Compability-Layer",
  "version": "0.1.0",
  "description": "Minecraft-protocol browser client — your own IP, built from scratch",
  "main": "src/server/index.js",
  "scripts": {
    "start":       "node src/server/index.js",
    "dev":         "nodemon src/server/index.js",
    "build":       "webpack --config webpack.config.js --mode production",
    "build:dev":   "webpack --config webpack.config.js --mode development --watch",
    "update-data": "node src/client/updater/sync.js"
  },
  "dependencies": {
    "minecraft-protocol":  "^1.47.0",
    "prismarine-auth":     "^2.6.0",
    "prismarine-viewer":   "^1.28.0",
    "mineflayer":          "^4.23.0",
    "prismarine-proxy":    "^1.4.0",
    "minecraft-data":      "^3.65.0",
    "express":             "^4.19.2",
    "ws":                  "^8.18.0",
    "node-fetch":          "^2.7.0",
    "fs-extra":            "^11.2.0",
    "semver":              "^7.6.3",
    "dotenv":              "^16.4.5",
    "cors":                "^2.8.5"
  },
  "devDependencies": {
    "webpack":             "^5.91.0",
    "webpack-cli":         "^5.1.4",
    "webpack-dev-server":  "^5.0.4",
    "babel-loader":        "^9.1.3",
    "@babel/core":         "^7.24.0",
    "@babel/preset-env":   "^7.24.0",
    "nodemon":             "^3.1.0",
    "css-loader":          "^7.1.1",
    "style-loader":        "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "GPL-3.0"
}
